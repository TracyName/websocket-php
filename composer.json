{
  "name": "tracyname/websocket-php",
  "description": "WebSocket сервер на php (построен на базе Workerman)",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Ignatiy Cheurin",
      "email": "info@egnotka.ru",
      "role": "Developer"
    }
  ],
  "autoload": {
    "psr-4": {
      "WebSocketPHP\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WebSocketPHP\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.2.0",
    "ext-json": "*",
    "monolog/monolog": "3.10.*",
    "workerman/workerman": "4.2.*"
  },
  "require-dev": {
    "phpunit/phpunit": "10.5.*"
  },
  "suggest": {
    "ext-posix": "Needed on Linux to access signal and process functions",
    "ext-pcntl": "Needed on Linux to handle signals in long-running worker processes",
    "ext-event": "Improves Workerman event loop performance"
  }
}
